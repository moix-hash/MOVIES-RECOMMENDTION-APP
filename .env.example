# ─── TMDB ────────────────────────────────
# Get free key at: https://www.themoviedb.org/settings/api
TMDB_API_KEY=your_tmdb_api_key_here

# ─── Firebase ────────────────────────────
# Get from: console.firebase.google.com → Project Settings → Your Apps
FIREBASE_API_KEY=your_firebase_api_key
FIREBASE_AUTH_DOMAIN=your_project.firebaseapp.com
FIREBASE_PROJECT_ID=your_project_id
FIREBASE_STORAGE_BUCKET=your_project.appspot.com
FIREBASE_MESSAGING_SENDER_ID=your_sender_id
FIREBASE_APP_ID=your_app_id

# ─── Google OAuth ─────────────────────────
# Get from: console.cloud.google.com → APIs & Services → Credentials
# Create OAuth 2.0 Client IDs for: Web, iOS, Android
GOOGLE_EXPO_CLIENT_ID=your_expo_client_id.apps.googleusercontent.com
GOOGLE_IOS_CLIENT_ID=your_ios_client_id.apps.googleusercontent.com
GOOGLE_ANDROID_CLIENT_ID=your_android_client_id.apps.googleusercontent.com
GOOGLE_WEB_CLIENT_ID=your_web_client_id.apps.googleusercontent.com
